FROM ubuntu:24.04

RUN sed -i 's|http://archive.ubuntu.com/ubuntu|http://mirrors.edge.kernel.org/ubuntu|g; s|http://security.ubuntu.com/ubuntu|http://mirrors.edge.kernel.org/ubuntu|g' /etc/apt/sources.list.d/ubuntu.sources

# Install basic development tools, ca-certificates, and iptables/ipset, then clean up apt cache to reduce image size
RUN apt-get update && apt-get install -y --no-install-recommends \
  aggregate \
  ca-certificates \
  curl \
  dnsutils \
  fzf \
  gh \
  git \
  gnupg2 \
  iproute2 \
  ipset \
  iptables \
  jq \
  less \
  man-db \
  procps \
  unzip \
  ripgrep \
  zsh

RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
  && apt-get install -y --no-install-recommends nodejs

RUN curl -fsSL https://bun.com/install | bash
ENV PATH=$PATH:/root/.bun/bin:/root/.local/bin

# Install codex from npm globally
RUN bun install -g @openai/codex@latest @fission-ai/openspec@latest openspecui@latest
RUN bun install -g @mariozechner/pi-coding-agent task-factory
RUN curl -fsSL https://claude.ai/install.sh | bash

RUN bunx playwright install --with-deps chrome chromium-headless-shell
RUN bunx skills add pbakaus/impeccable -g --agent claude-code -y

# Set npm global config for any user
ENV NPM_CONFIG_PREFIX=/usr/local/share/npm-global

# Inside the container we consider the environment already sufficiently locked
# down, therefore instruct Codex CLI to allow running without sandboxing.
ENV CODEX_UNSAFE_ALLOW_NO_SANDBOX=1
# Yes claude, it's fine
ENV IS_SANDBOX=1
ENV COLORTERM=truecolor

RUN mkdir -p /app
WORKDIR /app

CMD [ "openspecui" ]
