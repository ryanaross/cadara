{
  "name": "onshape-clone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:sketch-stability": "bun run test:editor-state-machine && bun run test:mock-kernel-contract && bun run test:occ-phase2 && bun run test:occ-phase6 && bun run test:e2e",
    "test:editor-state-machine": "bun x vite-node src/contracts/editor/state-machine.spec.ts",
    "test:solver-contract": "bun x vite-node src/contracts/solver/solver-contract.spec.ts",
    "test:sketch-solver": "bun x vite-node src/contracts/sketch/solver-core.spec.ts",
    "test:mock-kernel-contract": "bun x vite-node src/domain/modeling/mock-kernel-adapter.spec.ts",
    "test:occ-phase0": "bun x vite-node src/domain/modeling/occ/implementation-policy.spec.ts",
    "test:occ-phase1-runtime": "bun x vite-node src/domain/modeling/occ/runtime.spec.ts",
    "test:occ-phase1-browser-compile": "vite build --config vite.occ-runtime-browser-smoke.config.ts",
    "test:occ-phase1": "bun run test:occ-phase1-runtime && bun run test:occ-phase1-browser-compile",
    "test:occ-phase2": "bun x vite-node src/domain/modeling/occ/planes.spec.ts",
    "test:occ-phase3": "bun x vite-node src/domain/modeling/occ/sketch-profile.spec.ts",
    "test:occ-phase4": "bun x vite-node src/domain/modeling/occ/features.spec.ts",
    "test:occ-phase5": "bun x vite-node src/domain/modeling/occ/topology.spec.ts",
    "test:occ-phase6": "bun x vite-node src/domain/modeling/occ/snapshot.spec.ts",
    "test:occ-phase7": "TSX_TSCONFIG_PATH=tsconfig.test.json node --import tsx src/domain/modeling/opencascade-kernel-adapter.spec.ts",
    "test:occ-phase8": "TSX_TSCONFIG_PATH=tsconfig.test.json node --import tsx src/domain/modeling/opencascade-kernel-adapter.spec.ts",
    "test:occ-phase9": "bun run test:occ-phase1-browser-compile && bun run test:occ-phase8 && bun run build",
    "test:contract-examples": "bun x vite-node src/contracts/shared/contract-examples.spec.ts",
    "test:render-picking": "bun x vite-node src/domain/workspace/render-picking.spec.ts"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "opencascade.js": "^2.0.0-beta.b5ff984",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-node": "^3.2.4"
  }
}
